# ─────────────────────────────────────────────
#  FRIDAY Chatbot — Environment Variables
# ─────────────────────────────────────────────

# ✅ GROQ API Key (FREE) — get yours at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (free models below — pick one)
# llama-3.3-70b-versatile   ← best overall (recommended)
# llama-3.1-8b-instant      ← fastest
# mixtral-8x7b-32768        ← great for long context
# gemma2-9b-it              ← Google's Gemma 2
GROQ_MODEL=llama-3.3-70b-versatile

# Grok API Key (xAI) — get yours at https://console.x.ai/
XAI_API_KEY=your_grok_xai_api_key_here

# Active provider: "groq" | "grok" | "ollama" | "langchain"
NEXT_PUBLIC_AI_PROVIDER=groq

# Ollama settings (only needed if using Ollama locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
